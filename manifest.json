{
  "manifest_version": 3,
  "name": "Block Blue Check Mentions",
  "description": "트윗 원문에 멘션된 블루 체크 계정을 버튼 한 번으로 차단합니다.",
  "version": "0.1.0",
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.twitter.com/*"
  ]
}
